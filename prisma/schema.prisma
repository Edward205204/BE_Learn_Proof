generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String             @id @default(cuid())
  email             String             @unique
  password          String
  fullName          String
  avatar            String?
  role              Role               @default(LEARNER)
  isDeleted         Boolean            @default(false)
  deletedAt         DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  certificates      Certificate[]
  coursesCreated    Course[]           @relation("CourseCreator")
  discussions       Discussion[]
  enrollments       Enrollment[]
  heartbeats        LessonHeartbeat[]
  progress          Progress[]
  quizAttempts      QuizAttempt[]
  refreshTokens     RefreshToken[]
  replies           Reply[]
  reviews           Review[]
  transactions      Transaction[]
  verificationCodes VerificationCode[]

  @@index([email])
}

model VerificationCode {
  id        Int                  @id @default(autoincrement())
  email     String               @db.VarChar(500)
  code      String               @db.VarChar(50)
  type      VerificationCodeType
  expiresAt DateTime
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  userId    String?
  user      User?                @relation(fields: [userId], references: [id])

  @@unique([email, code])
  @@unique([email, type])
  @@index([email, code, type])
  @@index([expiresAt])
}

model RefreshToken {
  token     String   @unique @db.VarChar(1000)
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([expiresAt])
}

model Category {
  id      String   @id @default(cuid())
  name    String   @unique
  slug    String   @unique
  courses Course[]
}

model Course {
  id                    String                  @id @default(cuid())
  title                 String
  slug                  String                  @unique
  categoryId            String
  level                 CourseLevel             @default(BEGINNER)
  isCompleted           Boolean                 @default(false)
  publishedLessonsCount Int                     @default(0)
  totalPlannedLessons   Int?
  shortDesc             String
  fullDesc              String
  thumbnail             String?
  status                CourseStatus            @default(DRAFT)
  isFree                Boolean                 @default(true)
  price                 Float                   @default(0)
  originalPrice         Float?
  expectedDays          Int?
  creatorId             String
  createdAt             DateTime                @default(now())
  updatedAt             DateTime                @updatedAt
  certificates          Certificate[]
  chapters              Chapter[]
  category              Category                @relation(fields: [categoryId], references: [id])
  creator               User                    @relation("CourseCreator", fields: [creatorId], references: [id])
  dailySnapshots        CourseDailySnapshot[]
  overallAnalytics      CourseOverallAnalytics?
  discussions           Discussion[]
  enrollments           Enrollment[]
  reviews               Review[]
  transactions          Transaction[]

  @@unique([id, creatorId])
  @@index([creatorId])
}

model Chapter {
  id       String   @id @default(cuid())
  title    String
  order    Float
  courseId String
  course   Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons  Lesson[]
  quizzes  Quiz[]
}

model Lesson {
  id          String                   @id @default(cuid())
  title       String
  description String?
  contentAI   String?
  type        LessonType
  order       Float
  videoUrl    String?
  textContent String?
  duration    Int                      @default(0)
  chapterId   String
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt
  discussions Discussion[]
  chapter     Chapter                  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  analytics   LessonAnalyticsSnapshot?
  heartbeats  LessonHeartbeat[]
  progress    Progress[]
  quizzes     Quiz[]
}

model Quiz {
  id          String        @id @default(cuid())
  title       String?
  description String?
  lessonId    String?
  chapterId   String?
  createdAt   DateTime      @default(now())
  type        QuizType
  updatedAt   DateTime      @updatedAt
  questions   Question[]
  chapter     Chapter?      @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  lesson      Lesson?       @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  attempts    QuizAttempt[]

  @@index([lessonId])
  @@index([chapterId])
  @@index([type])
}

model QuizAttemptAnswer {
  id         String      @id @default(cuid())
  attemptId  String
  questionId String
  answerId   String
  isCorrect  Boolean
  answer     Answer      @relation(fields: [answerId], references: [id])
  attempt    QuizAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question   Question    @relation(fields: [questionId], references: [id])
}

model QuizAttempt {
  id        String              @id @default(cuid())
  userId    String
  quizId    String
  score     Float
  correct   Int
  total     Int
  createdAt DateTime            @default(now())
  quiz      Quiz                @relation(fields: [quizId], references: [id], onDelete: Cascade)
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers   QuizAttemptAnswer[]

  @@index([userId])
  @@index([quizId])
}

model Question {
  id             String              @id @default(cuid())
  content        String
  quizId         String
  createdAt      DateTime            @default(now())
  answers        Answer[]
  quiz           Quiz                @relation(fields: [quizId], references: [id], onDelete: Cascade)
  attemptAnswers QuizAttemptAnswer[]
}

model Answer {
  id             String              @id @default(cuid())
  content        String
  isCorrect      Boolean             @default(false)
  questionId     String
  question       Question            @relation(fields: [questionId], references: [id], onDelete: Cascade)
  attemptAnswers QuizAttemptAnswer[]
}

model Enrollment {
  id             String    @id @default(cuid())
  userId         String
  courseId       String
  enrolledAt     DateTime  @default(now())
  completedAt    DateTime?
  lastCaughtUpAt DateTime?
  course         Course    @relation(fields: [courseId], references: [id])
  user           User      @relation(fields: [userId], references: [id])

  @@unique([userId, courseId])
}

model Progress {
  id          String   @id @default(cuid())
  userId      String
  lessonId    String
  isCompleted Boolean  @default(false)
  lastAccess  DateTime @updatedAt
  lesson      Lesson   @relation(fields: [lessonId], references: [id])
  user        User     @relation(fields: [userId], references: [id])

  @@unique([userId, lessonId])
}

model LessonHeartbeat {
  id        String   @id @default(cuid())
  userId    String
  lessonId  String
  lastPoint Int
  updatedAt DateTime @updatedAt
  lesson    Lesson   @relation(fields: [lessonId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, lessonId])
}

model Discussion {
  id        String   @id @default(cuid())
  content   String
  isPinned  Boolean  @default(false)
  userId    String
  courseId  String
  lessonId  String
  createdAt DateTime @default(now())
  isDeleted Boolean  @default(false)
  course    Course   @relation(fields: [courseId], references: [id])
  lesson    Lesson   @relation(fields: [lessonId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
  replies   Reply[]

  @@index([courseId, lessonId])
  @@index([createdAt])
  @@index([isDeleted])
}

model Reply {
  id           String     @id @default(cuid())
  content      String
  discussionId String
  userId       String
  createdAt    DateTime   @default(now())
  isDeleted    Boolean    @default(false)
  discussion   Discussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id])

  @@index([discussionId])
  @@index([isDeleted])
}

model Review {
  id        String   @id @default(cuid())
  rating    Int      @default(5)
  comment   String?
  userId    String
  courseId  String
  createdAt DateTime @default(now())
  course    Course   @relation(fields: [courseId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, courseId])
}

model Transaction {
  id        String        @id @default(cuid())
  userId    String
  courseId  String
  amount    Float
  status    PaymentStatus @default(PENDING)
  provider  String
  createdAt DateTime      @default(now())
  course    Course        @relation(fields: [courseId], references: [id])
  user      User          @relation(fields: [userId], references: [id])
}

model Certificate {
  id              String   @id @default(cuid())
  userId          String
  courseId        String
  issuedAt        DateTime @default(now())
  certificateHash String   @unique
  txHash          String?
  course          Course   @relation(fields: [courseId], references: [id])
  user            User     @relation(fields: [userId], references: [id])
}

model CourseOverallAnalytics {
  id               String   @id @default(cuid())
  courseId         String   @unique
  totalStudents    Int      @default(0)
  totalRevenue     Float    @default(0)
  avgRating        Float    @default(0)
  avgInterestScore Float    @default(0)
  dropoutRate      Float    @default(0)
  completionRate   Float    @default(0)
  updatedAt        DateTime @updatedAt
  course           Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model CourseDailySnapshot {
  id             String   @id @default(cuid())
  courseId       String
  date           DateTime @default(now())
  newEnrollments Int      @default(0)
  activeLearners Int      @default(0)
  revenueToday   Float    @default(0)
  course         Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([courseId, date])
}

model LessonAnalyticsSnapshot {
  id           String   @id @default(cuid())
  lessonId     String   @unique
  totalViews   Int      @default(0)
  avgWatchTime Int      @default(0)
  dropOffCount Int      @default(0)
  quizPassRate Float?
  updatedAt    DateTime @updatedAt
  lesson       Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
}

enum Role {
  LEARNER
  CONTENT_MANAGER
  ADMIN
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum LessonType {
  VIDEO
  TEXT
  QUIZ
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
}

enum QuizType {
  LESSON
  CHAPTER
}

enum VerificationCodeType {
  REGISTER
  FORGOT_PASSWORD
}
