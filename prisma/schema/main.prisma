generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum VideoProvider {
  YOUTUBE
  BUNNY
  SELF_HOSTED
}

enum Role {
  LEARNER
  CONTENT_MANAGER
  ADMIN
}

enum CourseStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum CourseLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum LessonType {
  VIDEO
  TEXT
  QUIZ
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
}

enum QuizType {
  LESSON
  CHAPTER
}

enum VerificationCodeType {
  REGISTER
  FORGOT_PASSWORD
}
